# ---- Core ----
# Default output directory for generated meeting notes
MEETING_AGENT_OUTPUT_DIR=./output

# ---- LLM provider selection ----
# Values: ollama | anthropic | openai | azure_openai | hybrid
LLM_PROVIDER=ollama

# ---- Ollama (local) ----
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=gemma3:27b
# Optional: API key for a Caddy/reverse-proxy layer in front of Ollama
OLLAMA_API_KEY=

# ---- Anthropic ----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- OpenAI ----
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---- Azure OpenAI ----
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ---- Hybrid routing ----
# When LLM_PROVIDER=hybrid:
#   local-first: try local, fall back to cloud on failure
#   cloud-first: try cloud, fall back to local on failure
HYBRID_STRATEGY=local-first
HYBRID_LOCAL_PROVIDER=ollama
HYBRID_CLOUD_PROVIDER=anthropic
HYBRID_LOCAL_TIMEOUT_SECONDS=120

# ---- Template ----
# Path to a markdown template with placeholders like {{summary}}, {{action_items}}
MEETING_TEMPLATE=./templates/detailed_notes.md

# ---- Teams transcript source (optional) ----
# Only needed if using the Microsoft Teams source
TEAMS_TENANT_ID=
TEAMS_CLIENT_ID=
TEAMS_CLIENT_SECRET=
TEAMS_TARGET_USER_ID=
TEAMS_POLL_INTERVAL_SECONDS=300
